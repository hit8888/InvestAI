{
  "name": "@meaku/core",
  "version": "0.0.0",
  "scripts": {
    "dev": "tsc -w -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --reporter verbose",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage"
  },
  "main": "index.js",
  "sideEffects": false,
  "license": "MIT",
  "exports": {
    "./types/*": "./src/types/*.ts",
    "./utils/*": "./src/utils/*.ts",
    "./constants/*": "./src/constants/*.ts",
    "./hooks/*": "./src/hooks/*.tsx",
    "./queries/*": "./src/queries/*.ts",
    "./managers/*": "./src/managers/*.ts",
    "./transformers/*": "./src/transformers/*.ts",
    "./contexts/*": "./src/contexts/*.tsx"
  },
  "type": "module",
  "devDependencies": {
    "@meaku/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.9",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.8",
    "jsdom": "^26.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@sentry/react": "^8.30.0",
    "@tanstack/react-query": "^5.56.2",
    "ahooks": "^3.8.1",
    "axios": "^1.7.7",
    "lodash": "^4.17.21",
    "nanoid": "^5.0.7",
    "react": "^19.0.0",
    "react-day-picker": "8.10.1",
    "react-router-dom": "^6.26.2",
    "use-context-selector": "^2.0.0",
    "vite": "^6.0.7",
    "zod": "^3.23.8"
  }
}
