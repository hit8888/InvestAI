{
  "name": "@meaku/core",
  "version": "0.0.0",
  "scripts": {
    "dev": "tsc -w -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src/",
    "test": "vitest run --reporter verbose",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage"
  },
  "main": "index.js",
  "sideEffects": false,
