    "@radix-ui/react-slot": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "1.0.0",
    "framer-motion": "^11.16.4",
