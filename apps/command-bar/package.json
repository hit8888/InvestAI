{
  "name": "command-bar",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "rm -rf dist && vite",
    "dev:wc": "rm -rf dist/wc && pnpm build:wc && npx serve -l 3001",
    "build": "tsc -b && rm -rf dist && pnpm run build:wc",
    "build:wc": "NODE_ENV=production vite build --config vite.config-wc.ts",
    "build:app": "NODE_ENV=production vite build",
    "build:dev": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@calcom/embed-react": "^1.5.2",
    "@hookform/resolvers": "^3.9.1",
    "@r2wc/react-to-web-component": "^2.0.4",
    "@sentry/react": "^8.30.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dompurify": "^3.2.5",
    "@tanstack/react-query": "^5.56.2",
    "axios": "^1.11.0",
    "framer-motion": "^11.16.4",
    "md5": "^2.3.0",
    "nanoid": "^5.0.7",
    "libphonenumber-js": "^1.11.18",
    "lodash": "^4.17.21",
    "react": "^19.1.0",
    "react-calendly": "^4.3.1",
    "react-dom": "^19.1.0",
    "zod": "^3.24.2",
    "zustand": "5.0.0-rc.2",
    "react-hook-form": "^7.53.2",
    "react-phone-number-input": "^3.4.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@meaku/core": "workspace:*",
    "@meaku/saral": "workspace:*",
    "@meaku/shared": "workspace:*",
    "@sentry/vite-plugin": "^2.22.4",
    "@tanstack/react-query-devtools": "5.0.0-alpha.91",
    "@types/md5": "^2.3.5",
    "@types/lodash": "^4.17.9",
    "@types/node": "^22.5.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^16.4.5",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "postcss": "^8.5.6",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "code-inspector-plugin": "^1.2.6"
  }
}
