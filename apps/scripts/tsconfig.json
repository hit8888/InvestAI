{
  "extends": "@meaku/typescript-config/base.json",
  "include": ["."],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.spec.ts",
    "**/playwright.config.ts"
  ],
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@meaku/core/*": ["../../packages/core/src/*"]
    },
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "moduleResolution": "node",
    "module": "ESNext"
  }
}
