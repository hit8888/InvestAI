{
  "extends": "@meaku/typescript-config/base.json",
  "include": ["."],
  "exclude": ["dist", "build", "node_modules"],
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@meaku/core/*": ["../../packages/core/src/*"]
    },
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "moduleResolution": "node"
  }
}
