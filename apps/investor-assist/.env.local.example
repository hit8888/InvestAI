# Required: Groq API key for LLM analysis
# Get yours at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: NewsAPI key for broader news coverage (free tier: 100 req/day)
# Get yours at https://newsapi.org
# Without this, only Yahoo Finance RSS is used (still works, but fewer articles)
NEWS_API_KEY=your_newsapi_key_here

# Supabase — required for Google SSO + Postgres portfolio persistence
# Get these from your Supabase project settings: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
