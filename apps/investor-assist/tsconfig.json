{
  "extends": "@neuraltrade/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "ES2017", "esnext"],
    "paths": {
      "@/*": ["./*"]
