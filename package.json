{
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "lint-staged": "lint-staged",
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:chat": "turbo run dev --filter=chatbot --filter=@breakout/design-system --filter=@meaku/core",
    "dev:admin": "turbo run dev --filter=agent-admin --filter=@breakout/design-system --filter=@meaku/core",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch"
  },
  "devDependencies": {
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "turbo": "^2.1.1"
  },
  "packageManager": "pnpm@8.15.6",
  "engines": {
    "node": ">=18"
  },
"pnpm": {
    "overrides": {
      "agent-admin>react": "^19.0.0",
      "agent-admin>react-dom": "^19.0.0",
      "chatbot>react": "^18.3.1",
      "chatbot>react-dom": "^18.3.1"
    },
    "packageExtensions": {
      "agent-admin": {
        "peerDependencies": {
          "react": ">=19.0.0",
          "react-dom": ">=19.0.0"
        }
      }
    },
    "shamefullyHoist": false,
    "strictPeerDependencies": true
  },
  "lint-staged": {
    "apps/**/*.{js,jsx,ts,tsx}": [
      "eslint --config apps/chatbot/eslint.config.js --fix",
      "eslint --config apps/agent-admin/eslint.config.js --fix",
      "prettier --write"
    ],
    "{apps,packages}/**/*.{json,md,html,css}": [
      "prettier --write"
    ]
  },
  "name": "meaku"
}
