{
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "husky install",
    "lint-staged": "lint-staged",
    "build": "turbo build",
    "dev": "turbo dev",
    "dev:agent": "turbo run dev --filter=agent --filter=@breakout/design-system --filter=@meaku/core",
    "dev:admin": "turbo run dev --filter=agent-admin --filter=@breakout/design-system --filter=@meaku/core",
    "dev:scripts": "turbo run dev --filter=scripts",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "turbo": "^2.1.1",
    "typescript-eslint": "^8.24.1"
  },
  "packageManager": "pnpm@10.2.0",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.0.8",
      "@types/react-dom": "19.0.3"
    }
  },
  "lint-staged": {
    "{apps,packages}/**/*.{js,jsx,ts,tsx}": [
      "eslint --config eslint.config.base.js --fix",
      "prettier --write"
    ],
    "{apps,packages}/**/*.{json,md,html,css}": [
      "prettier --write"
    ]
  },
  "name": "meaku"
}